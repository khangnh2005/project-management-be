extends ../../layout/default.pug
include ../../mixins/pagination.pug
include ../../mixins/table-tree.pug
include ../../mixins/alert.pug

block main 
    if(role.permissions.includes("roles_view"))  
        h1 Nhóm Quyền   
        +alert-success(5000)

        .card.mb-3
            .card-header Danh sách  
            .card-body
                .row 
                    .col-4
                        if(role.permissions.includes("roles_create"))   
                            a(
                                href=`${prefixAdmin}/roles/create`
                                class = "btn btn-outline-success"
                            ) + Thêm mới 

                table( class="table table-hover table-sm" check-box-multi table-permissions)
                    thead
                        tr
                            th Tiêu đề
                            th Mô tả ngắn
                            th Hành động
                    tbody
                        each item  in records
                            tr 
                                td #{item.title}
                                td #{item.description}
                                td
                                    if(role.permissions.includes("roles_edit"))   
                                        button(class="btn btn-warning btn-sm ml-1")
                                            a(href=`${prefixAdmin}/roles/edit/${item.id}` style="color:white") Sửa
                                    if(role.permissions.includes("roles_delete"))     
                                        button(
                                            class="btn btn-danger btn-sm ml-1" 
                                            data-id = item.id
                                            button-delete 
                                            ) Xóa

                                        
        
        form(
            action=""
            method="POST"
            id = "form-delete-item"
            data-path2 = `${prefixAdmin}/roles/delete`
        )
        script(src="/admin/js/products.js") 
