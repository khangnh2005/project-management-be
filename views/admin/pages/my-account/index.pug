extends ../../layout/default.pug
include ../../mixins/alert.pug

block main 
    +alert-success(5000)
    if(user.avatar)
        img(src=user.avatar width="300px" height="200px")
    else 
        img(src="data:image/jpeg;base64," width="250px" height="200px")
    h2 Họ và tên #{user.fullName}
    h3 Email : #{user.email}
    h3 Số điện thoại : #{user.phone}
    h3 Phân quyền : #{role.title}
    button(class="btn btn-warning btn-sm ml-1")
        a(href=`${prefixAdmin}/my-account/edit` style="color:white") Chỉnh sửa thông tin