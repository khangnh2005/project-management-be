extends ../../layout/default.pug
include ../../mixins/alert.pug

block main   
    if(role.permissions.includes("accounts_view"))  
        +alert-success(5000)
        .card.mb-3
            .card-header Danh Sách
            .card-body
                .row 
                    .col-4
                        if(role.permissions.includes("accounts_create"))
                            a(
                                href=`${prefixAdmin}/accounts/create`
                                class = "btn btn-outline-success"
                            ) + Thêm mới 
            
            table( class="table table-hover table-sm" check-box-multi)
                    thead
                        tr
                            th 
                                input(type="checkbox" name = "checkall")
                            th Ảnh đại diện
                            th Họ và tên
                            th Email
                            th Vai trò
                            th Trạng thái
                            th Hành động
                    tbody
                        each item in records
                            tr
                                td 
                                    input(type="checkbox" name="id" value= item.id)
                                td
                                    img(
                                    src= item.avatar
                                    alt= item.fullName
                                    width="100px"
                                    height="auto"
                                    )
                                td #{item.fullName} 
                                td #{item.email}
    
                                td 
                                    each role in roles 
                                        if(role.id == item.role_id)
                                            p #{role.title}
                                td  
                                    if(item.status == 'active')
                                        a(
                                            href="javascript:;" 
                                            button-change-status
                                            data-status= item.status
                                            data-id = item.id
                                            class="badge badge-success" 
                                        ) Hoạt động
                                    else 
                                        a(
                                            href="javascript:;"
                                            button-change-status 
                                            data-status= item.status 
                                            data-id = item.id
                                            class="badge badge-danger" 
                                        ) Dừng Hoạt động 
                                td
                                    if(role.permissions.includes("accounts_edit"))  
                                        button(class="btn btn-warning btn-sm ml-1")
                                            a(href=`${prefixAdmin}/accounts/edit/${item.id}` style="color:white") Sửa
                                    if(role.permissions.includes("accounts_delete"))
                                        button(
                                            class="btn btn-danger btn-sm ml-1" 
                                            data-id = item.id
                                            button-delete 
                                            ) Xóa

        form(
            action=""
            method="POST"
            id = "form-delete-item"
            data-path2 = `${prefixAdmin}/accounts/delete`
        )  
        script(src="/admin/js/products.js") 