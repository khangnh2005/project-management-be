extends ../../layouts/default.pug
include ../../mixins/alert.pug
block main
    +alert-error(4000)
    +alert-success(4000)
    .container.my-5
        .row.justify-content-center
            .col-8
                h1(class="text-center") Đăng ký tài khoản
                form(
                    action=`/user/register`
                    method="POST"
                )
                    div(class="form-group")
                        label(for="fullName") Họ và tên
                        input(
                            type="fullName"
                            class="form-control"
                            id="fullName"
                            name="fullName"
                        )
                    div(class="form-group")
                        label(for="email") Email
                        input(
                            type="email"
                            class="form-control"
                            id="email"
                            name="email"
                            
                        )
                    if (error && errorField === "email")
                        div(class="text-danger" style="font-size: 14px; margin-top: 4px;") #{error}
                    div(class="form-group")
                        label(for="password") Mật khẩu
                        input(
                            type="password"
                            class="form-control"
                            id="password"
                            name="password"
                            
                        )
                    if (error && errorField === "password")
                        div(class="text-danger" style="font-size: 14px; margin-top: 4px;") #{error}
                    br
                    div(class="form-group")
                        button(
                            type="submit"
                            class="btn btn-primary btn-block"
                        ) Đăng ký
